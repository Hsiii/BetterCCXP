{
  "manifest_version": 3,
  "name": "Better CCXP",
  "version": "0.1.0",
  "description": "Simplifies the NTHU CCXP entry header on the main inquiry page.",
  "content_scripts": [
    {
      "matches": [
        "https://www.ccxp.nthu.edu.tw/ccxp/INQUIRE/",
        "https://www.ccxp.nthu.edu.tw/ccxp/INQUIRE/index.php*",
        "https://www.ccxp.nthu.edu.tw/ccxp/INQUIRE/select_entry.php*"
      ],
      "run_at": "document_idle",
      "js": [
        "content.js"
      ]
    }
  ]
}
